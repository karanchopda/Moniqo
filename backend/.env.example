# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string (URI mode)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="CHANGE_ME_USE_A_LONG_RANDOM_STRING_IN_PRODUCTION"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required for: AI Coach chat, statement analysis, PDF OCR, SMS parsing.
# Without this, all AI features return fallback/empty responses.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Used for file storage (PDF/CSV uploads).
# Supabase → Settings → API
SUPABASE_URL=https://[PROJECT-ID].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─── CORS & Email Links ───────────────────────────────────────────────────────
# The URL where your frontend is running. Used in email links and CORS.
FRONTEND_URL=http://localhost:3000

# Optional: extra comma-separated origins for CORS (e.g. Vercel preview URLs)
# CORS_ORIGINS=https://moniqoai.vercel.app,https://www.moniqo.com

# ─── Redis (optional — BullMQ background processing) ─────────────────────────
# If Redis is NOT running, the server still starts and processes uploads
# synchronously. Redis enables async background processing for large files.
# Install locally: brew install redis && brew services start redis
# Or use a managed Redis (Upstash, Redis Cloud, Railway)
REDIS_URL=redis://127.0.0.1:6379

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Without SMTP, email verification/reset links are printed to the console only.
# Users can still sign up and use the app — they just can't receive emails.
#
# HOW TO ENABLE:
#
# OPTION A — Gmail (quickest for dev/testing)
#   1. Enable 2FA on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail"
#   4. Fill in the values below:
#
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx   ← 16-char App Password (no spaces)
#
# OPTION B — Resend (recommended for production, generous free tier)
#   1. Sign up at https://resend.com
#   2. Create an API key
#   3. Verify your sending domain (or use onboarding@resend.dev for testing)
#
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
#
# OPTION C — SendGrid
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxx
#
# Sender name and address shown in email clients:
# EMAIL_FROM=Moniqo <noreply@moniqo.com>
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Moniqo <noreply@moniqo.com>

# ─── Stripe (Payments) ────────────────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
# Create Products + Prices in Stripe Dashboard, then paste Price IDs below.
# Currency: INR (Indian Rupees). Use test mode keys during development.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Monthly price IDs (create in Stripe → Products → Add price)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...
STRIPE_PRICE_ELITE_YEARLY=price_...
