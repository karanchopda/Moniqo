# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# Authentication
JWT_SECRET="super_secret_key_for_mvp_change_in_production"

# OpenAI Configuration
OPENAI_API_KEY="sk-..."

# Supabase Configuration
SUPABASE_URL=https://[PROJECT-ID].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Optional comma-separated extra origins for CORS
# CORS_ORIGINS=https://moniqoai.vercel.app,https://www.moniqo.com

# Redis Configuration (for BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# Email Configuration — Nodemailer SMTP
# Leave all SMTP_* values blank in development to use the console fallback (links are logged).
# To send real emails, fill in the values for your chosen provider below.
#
# OPTION 1 — Gmail (use an App Password, not your real password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your_16_char_app_password
#
# OPTION 2 — SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.your_sendgrid_api_key
#
# OPTION 3 — Resend (via SMTP relay):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_your_resend_api_key
#
# Sender display name & address shown in email clients:
# EMAIL_FROM=Moniqo <noreply@moniqo.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Moniqo <noreply@moniqo.com>
