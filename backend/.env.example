# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# Authentication
JWT_SECRET="super_secret_key_for_mvp_change_in_production"

# OpenAI Configuration
OPENAI_API_KEY="sk-..."

# Supabase Configuration
SUPABASE_URL=https://[PROJECT-ID].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Optional comma-separated extra origins for CORS
# CORS_ORIGINS=https://moniqoai.vercel.app,https://www.moniqo.com

# Redis Configuration (for BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# Email Configuration — Nodemailer SMTP
# Works with any SMTP provider: Gmail, SendGrid, Mailgun, etc.
# Leave blank in development to use console fallback
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=Moniqo <noreply@moniqo.com>
